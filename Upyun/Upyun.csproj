<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>net6.0;netstandard2.0</TargetFrameworks>
        <Authors>BitBrewing</Authors>
        <Company>Yiqifei</Company>
        <Description>又拍云SDK</Description>
        <PackageProjectUrl>https://github.com/BitBrewing/upyun-csharp-sdk</PackageProjectUrl>
        <RepositoryUrl>https://github.com/BitBrewing/upyun-csharp-sdk</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageTags>upyun;又拍云</PackageTags>
        <GenerateDocumentationFile>True</GenerateDocumentationFile>
    </PropertyGroup>

    <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
        <PackageReference Include="System.Text.Json" Version="6.0.11" />
    </ItemGroup>

    <ItemGroup>
        <None Include="..\README.md" Pack="true" PackagePath="\" />
    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="Mime-Detective" Version="22.7.21" />
    </ItemGroup>

</Project>
